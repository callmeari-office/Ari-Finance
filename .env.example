# Chuỗi kết nối đến cơ sở dữ liệu PostgreSQL (lấy từ Neon.tech hoặc Supabase)
# Hãy sao chép tệp này thành tệp .env và dán đường dẫn thực tế của bạn vào
DATABASE_URL="postgresql://neondb_owner:password@host/neondb?sslmode=require"

# ===== Gửi email thông báo (Gmail SMTP) =====
# SMTP_PASS là "App Password" 16 ký tự tạo tại https://myaccount.google.com/apppasswords
# (cần bật Xác minh 2 bước). KHÔNG dùng mật khẩu đăng nhập Gmail thường.
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM="Ari-Finance <your-email@gmail.com>"
APP_URL="http://localhost:3000"

# ===== Web Push Notification (VAPID) =====
# Tạo cặp key bằng lệnh: npx web-push generate-vapid-keys
# VAPID_SUBJECT phải là "mailto:your-email@domain.com" hoặc URL app
VAPID_SUBJECT="mailto:your-email@gmail.com"
VAPID_PUBLIC_KEY="your-base64url-public-key"
VAPID_PRIVATE_KEY="your-base64url-private-key"

# ===== Bảo vệ Cron Job (Vercel Cron) =====
# Tạo chuỗi ngẫu nhiên bất kỳ (vd: openssl rand -hex 32). Đặt cùng giá trị trong Vercel Dashboard.
CRON_SECRET="your-random-secret-string"

# ===== Email "Báo cáo sáng" (Daily Morning Briefing) =====
# Bật gửi email tóm tắt 8:00 sáng mỗi ngày cho Owner + Manager. Để "on" để bật, bỏ trống/khác = tắt.
EMAIL_BAO_CAO_SANG="off"
# Khóa API Claude (Anthropic) — dùng cho đoạn "nhận định + đề xuất" AI trong email báo cáo sáng.
# Lấy tại https://console.anthropic.com . Thiếu key thì email vẫn gửi, chỉ bỏ phần AI.
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ===== Supabase Storage (lưu ảnh hóa đơn) =====
# Lấy từ Supabase Dashboard → Project Settings → API
# SUPABASE_URL: Project URL (dạng https://xxx.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY: service_role key (KHÔNG phải anon key) — chỉ dùng server-side
# Trước khi dùng: tạo bucket "hoa-don" trong Storage → đặt Public = true
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
