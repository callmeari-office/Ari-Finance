datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model NhanVien {
  id        String    @id @default(uuid())
  hoTen     String
  tenNgan   String?   // Tên viết tắt/ngắn gọn (Ví dụ: Trúc Linh, Bảo Nam)

  email     String    @unique // Email liên hệ
  username  String    @unique // Tên đăng nhập (ID trơn)
  phone     String?   // Số điện thoại
  phongBan  String?   // Phòng ban (PHÒNG KẾ TOÁN, FINANCE & IT...)
  viTri     String?   // Vị trí (Giám đốc, Admin...)
  matKhau   String
  role      String    // OWNER, MANAGER, STAFF
  trangThai String    // ACTIVE, INACTIVE
  createdAt DateTime  @default(now())

  sessions            Session[]
  deXuatTao           DeXuatChiPhi[] @relation("NguoiTao")
  deXuatDuyet         DeXuatChiPhi[] @relation("NguoiDuyet")
  thuChiTao           ThuChi[]
  pushSubscriptions   PushSubscription[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  nhanVien  NhanVien @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model VaiTroQuyen {
  id          String @id @default(uuid())
  role        String @unique // OWNER, MANAGER, STAFF
  permissions String // Chuỗi JSON phân quyền module
}

model Quy {
  id            String   @id
  tenQuy        String
  loaiQuy       String
  soDuDauKy     Float
  soDuDieuChinh Float    @default(0) // Khoản điều chỉnh cân bằng thủ công (OWNER), không qua phiếu thu-chi
  trangThai     String   // ACTIVE, INACTIVE
  createdAt     DateTime @default(now())

  deXuatThanhToan DeXuatChiPhi[]
  thuChi          ThuChi[]
}

model NhomChiPhi {
  id        String    @id
  tenNhom   String
  thuTu     Int
  danhmuc   DanhMuc[]
}

model DanhMuc {
  id              String         @id
  tenDanhMuc      String
  nhomChiPhiId    String
  loaiGiaoDich    String         // CHI, THU
  chucVuDuocXem   String         // JSON string array, e.g. '["OWNER", "MANAGER", "STAFF"]'
  yeuCauNCC       Boolean
  trangThai       String         // ACTIVE, INACTIVE
  hanMucThang     Float?         // Hạn mức chi tháng (nếu có)

  nhomChiPhi      NhomChiPhi     @relation(fields: [nhomChiPhiId], references: [id])
  deXuatChiPhi    DeXuatChiPhi[]
  thuChi          ThuChi[]
  keHoach         KeHoach[]
}

model KeHoach {
  id        String   @id @default(uuid())
  nam       Int
  thang     Int      // 1-12
  danhMucId String
  soTien    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  danhMuc   DanhMuc  @relation(fields: [danhMucId], references: [id])

  @@unique([nam, thang, danhMucId])
}

model KenhBan {
  id        String   @id @default(uuid())
  tenKenh   String                       // POS, Shopee, Harasocial, Web, Zalo, Instagram...
  thuTu     Int      @default(0)          // thứ tự hiển thị
  mauSac    String?                       // mã màu cột biểu đồ (vd "#10b981")
  trangThai String   @default("ACTIVE")   // ACTIVE | INACTIVE (ẩn kênh thay vì xoá cứng)
  createdAt DateTime @default(now())

  keHoachDoanhThu  KeHoachDoanhThu[]
  doanhThuHangNgay DoanhThuHangNgay[]
}

model DoanhThuHangNgay {
  id        String   @id @default(uuid())
  ngay      DateTime // Ngày phát sinh doanh thu (đã chuẩn hóa giờ về 00:00:00 UTC)
  kenhBanId String
  soTien    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kenhBan   KenhBan  @relation(fields: [kenhBanId], references: [id])

  @@unique([ngay, kenhBanId])
}

model KeHoachDoanhThu {
  id        String   @id @default(uuid())
  nam       Int
  thang     Int      // 1-12
  kenhBanId String
  chiTieu   Float    @default(0)   // số kế hoạch (chỉ tiêu)
  thucTe    Float    @default(0)   // số thực tế (nhập tay)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kenhBan   KenhBan  @relation(fields: [kenhBanId], references: [id])

  @@unique([nam, thang, kenhBanId])
}

model NhaCungCap {
  id           String         @id
  tenNCC       String
  tenTaiKhoan  String?        // Tên chủ tài khoản ngân hàng (tách biệt với tên đối tác)
  soTaiKhoan   String
  tenNganHang  String
  maQR         String?
  loaiDoiTuong String         @default("NCC") // (Cột cũ - không còn dùng trong code; giữ lại để tránh migration phá trên Windows)
  chucVuDuocXem String?       // JSON mảng vai trò được xem (vd ["MANAGER","LEADER"]); NULL = mọi vai trò xem được

  deXuatChiPhi DeXuatChiPhi[]
  thuChi       ThuChi[]
}

model DeXuatChiPhi {
  id               String      @id @default(uuid())
  maPhieu          String      @unique
  ngayPhatSinh     DateTime
  danhMucId        String
  noiDung          String
  soTien           Float
  nhaCungCapId     String?
  anhHoaDon        String?     // base64 hoặc URL
  nguonTien        String      // TIEN_SHOP, TIEN_CA_NHAN
  trangThai        String      // CHO_THANH_TOAN, CHO_HOAN_UNG, DA_THANH_TOAN, HUY
  quyThanhToanId   String?
  thuChiId         String?
  nguoiTaoId       String
  ngayThanhToan    DateTime?
  nguoiDuyetId     String?
  ghiChu           String?
  ngayTao          DateTime    @default(now())
  ngayCanThanhToan DateTime?   // Ngày cần thanh toán mong muốn
  laLichSu         Boolean     @default(false) // Phiếu nhập từ dữ liệu cũ (đã thanh toán, không trừ quỹ, không cần duyệt)


  danhMuc         DanhMuc     @relation(fields: [danhMucId], references: [id])
  nhaCungCap      NhaCungCap? @relation(fields: [nhaCungCapId], references: [id])
  quyThanhToan    Quy?        @relation(fields: [quyThanhToanId], references: [id])
  thuChi          ThuChi?     @relation(fields: [thuChiId], references: [id], onDelete: SetNull)
  nguoiTao        NhanVien    @relation("NguoiTao", fields: [nguoiTaoId], references: [id])
  nguoiDuyet      NhanVien?   @relation("NguoiDuyet", fields: [nguoiDuyetId], references: [id])

  @@index([trangThai])
  @@index([ngayPhatSinh])
  @@index([nguoiTaoId])
  @@index([danhMucId])
  @@index([ngayCanThanhToan])
}

model ThuChi {
  id            String    @id @default(uuid())
  maPhieu       String    @unique
  ngayGiaoDich  DateTime
  loaiGiaoDich  String    // CHI, THU
  soTien        Float
  quyId         String
  danhMucId     String
  nhaCungCapId  String?
  noiDung       String
  nguoiTaoId    String
  ghiChu        String?
  ngayTao       DateTime  @default(now())

  quy           Quy       @relation(fields: [quyId], references: [id])
  danhMuc       DanhMuc   @relation(fields: [danhMucId], references: [id])
  nhaCungCap    NhaCungCap? @relation(fields: [nhaCungCapId], references: [id])
  nguoiTao      NhanVien  @relation(fields: [nguoiTaoId], references: [id])
  deXuatChiPhi  DeXuatChiPhi[]

  @@index([ngayGiaoDich])
  @@index([danhMucId])
  @@index([quyId])
  @@index([loaiGiaoDich, ngayGiaoDich])
}

model NganHang {
  id          String   @id @default(uuid())
  tenVietTat  String   @unique // Ví dụ: VCB, TCB, MB
  tenDayDu    String   // Ví dụ: Vietcombank, Techcombank
  createdAt   DateTime @default(now())
}

// Token đặt lại mật khẩu do OWNER gửi — TTL 1 giờ, dùng 1 lần.
model PasswordResetToken {
  id         String   @id @default(uuid())
  token      String   @unique @default(uuid())
  nhanVienId String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([nhanVienId])
}

// Phiếu chi định kỳ (template tái diễn hàng tháng).
model PhieuDinhKy {
  id                String   @id @default(uuid())
  tenMau            String
  noiDung           String
  soTien            Float
  danhMucId         String
  nhaCungCapId      String?
  nguonTien         String
  trangThaiMacDinh  String   @default("CHO_THANH_TOAN")
  ngayChiTrongThang Int      @default(1)
  ghiChu            String?
  active            Boolean  @default(true)
  nguoiTaoId        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Đăng ký nhận Web Push Notification theo từng trình duyệt/thiết bị.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique  // URL endpoint do browser cấp
  p256dh    String            // Public key mã hoá payload
  auth      String            // Auth secret
  createdAt DateTime @default(now())

  nhanVien  NhanVien @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Bảng thông báo nội bộ — hiển thị ngay đầu trang Tổng quan.
// Bảng được tạo bằng raw SQL (prisma/add-thong-bao.js) — xem lưu ý Prisma 7 db push trên Windows.
model ThongBaoNoiBo {
  id          String    @id @default(uuid())
  tieuDe      String
  noiDung     String
  tag         String    @default("THONG_TIN") // QUAN_TRONG | NHAC_NHO | THONG_TIN
  ngayHetHan  DateTime?
  trangThai   String    @default("ACTIVE")    // ACTIVE | ARCHIVED
  nguoiTaoId  String
  tenNguoiTao String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([trangThai])
  @@index([ngayHetHan])
}

// Bảng đếm thử đăng nhập sai để chống brute-force xuyên instance serverless.
model LoginAttempt {
  key          String @id
  count        Int    @default(0)
  firstAt      BigInt @default(0)
  blockedUntil BigInt @default(0)
  updatedAt    BigInt @default(0)
}

// Nhật ký thao tác (audit log) — ghi lại ai làm gì, lúc nào.
// Bảng độc lập, không khóa ngoại để xóa nhân viên không ảnh hưởng lịch sử.
// Bảng được tạo bằng raw SQL (prisma/add-lichsuthaotac.js) — xem lưu ý Prisma 7 db push trên Windows.
model LichSuThaoTac {
  id           String   @id @default(uuid())
  thoiGian     DateTime @default(now())
  nguoiDungId  String?  // id NhanVien (snapshot, không FK)
  tenNguoiDung String?  // tên hiển thị tại thời điểm thao tác
  vaiTro       String?  // OWNER/MANAGER/LEADER/STAFF
  hanhDong     String   // DANG_NHAP, DOI_MAT_KHAU, TAO, SUA, DUYET, HUY, XOA...
  doiTuong     String?  // DE_XUAT, THU_CHI, NHAN_VIEN, QUY...
  maDoiTuong   String?  // mã/ID đối tượng bị tác động
  moTa         String?  // mô tả ngắn gọn

  @@index([thoiGian])
}
